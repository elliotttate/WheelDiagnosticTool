<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WheelDiagnosticTool.Views.ButtonDiscoveryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock x:Name="Title" Text="Identify wheel-rim buttons" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock Opacity="0.85" TextWrapping="Wrap"
                       Text="For each labeled action below, press the button on your wheel/shifter and click 'Capture'. Press 'Skip' for any you don't have. The tool only records which button number fires — you tell it what the button is."/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="Current target:" Opacity="0.7"/>
                <TextBlock x:Name="CurrentTarget" Text="" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock x:Name="LastPressed" Text="No button pressed yet" Margin="0,8,0,0" Opacity="0.85"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ResultList"/>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="SkipButton" Click="OnSkipCurrent">Skip this button</Button>
            <Button x:Name="CaptureButton" Click="OnCaptureCurrent" Style="{ThemeResource AccentButtonStyle}" IsEnabled="False">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Capture pressed button"/>
                </StackPanel>
            </Button>
            <Button x:Name="DoneButton" Click="OnDone">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Done with buttons"/>
                    <FontIcon Glyph="&#xE0AB;" FontSize="14"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Page>
