<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WheelDiagnosticTool.Views.DeviceSelectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Pick the device to characterize" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock Opacity="0.8" TextWrapping="Wrap"
                       Text="This is typically your steering wheel. If you have a separate pedal or shifter device, just pick the wheel here — pedal/shifter axes will be discovered automatically through the prompts."/>
        </StackPanel>

        <ListView x:Name="DeviceList"
                  Grid.Row="1"
                  Margin="0,16,0,0"
                  SelectionMode="Single"
                  SelectionChanged="OnSelectionChanged"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BackButton" Click="OnBack">Back</Button>
            <Button x:Name="NextButton" Style="{ThemeResource AccentButtonStyle}" Click="OnNext" IsEnabled="False">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Continue"/>
                    <FontIcon Glyph="&#xE0AB;" FontSize="14"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Page>
