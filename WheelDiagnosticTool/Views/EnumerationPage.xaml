<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WheelDiagnosticTool.Views.EnumerationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Detecting hardware" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock x:Name="SubText"
                       Text="Enumerating DirectInput, XInput, raw HID and running vendor software..."
                       Opacity="0.8"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,24,0,0"
                      VerticalScrollMode="Auto"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14">
                <StackPanel Spacing="6">
                    <TextBlock Text="DirectInput devices" FontSize="16" FontWeight="SemiBold"/>
                    <ItemsControl x:Name="DiList"/>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="HID devices (vendor-filtered)" FontSize="16" FontWeight="SemiBold"/>
                    <ItemsControl x:Name="HidList"/>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="XInput slots" FontSize="16" FontWeight="SemiBold"/>
                    <ItemsControl x:Name="XInputList"/>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Running vendor software" FontSize="16" FontWeight="SemiBold"/>
                    <ItemsControl x:Name="VendorList"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="RescanButton" Click="OnRescanClicked">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    <TextBlock Text="Rescan"/>
                </StackPanel>
            </Button>
            <Button x:Name="NextButton" Style="{ThemeResource AccentButtonStyle}" Click="OnNextClicked">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Continue"/>
                    <FontIcon Glyph="&#xE0AB;" FontSize="14"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Page>
