<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>WheelDiagnosticToolSetup</AssemblyName>
    <RootNamespace>WheelDiagnosticToolLauncher</RootNamespace>

    <!--
      Launcher is a non-WinUI console-style WinExe. PublishSingleFile works
      for it (the 0xC000027B Microsoft.UI.Xaml.dll fault is specific to WinUI
      apps published this way). The inner WinUI app stays multi-file.
    -->
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>

    <!-- Suppress copy-on-build of the resource (it's huge). -->
    <ProduceReferenceAssembly>false</ProduceReferenceAssembly>
  </PropertyGroup>

  <ItemGroup>
    <!--
      The inner zip is generated by scripts\build_launcher.ps1 right before
      `dotnet publish`. The script writes Resources\WheelDiagnosticTool.zip
      from the multi-file Release publish folder, then publishes this csproj.
      MSBuild then embeds the zip as a manifest resource.
    -->
    <EmbeddedResource Include="Resources\WheelDiagnosticTool.zip"
                      Condition="Exists('Resources\WheelDiagnosticTool.zip')"
                      LogicalName="WheelDiagnosticTool.zip" />
  </ItemGroup>

</Project>
